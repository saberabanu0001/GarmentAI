# Copy to .env at repository root (never commit .env).
# Build Chroma: python scripts/ingest_laws.py

# ollama | groq | gemini
LLM_BACKEND=ollama

# Ollama (local)
# OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Groq — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (optional)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Database (future)
# DB_PASS=
