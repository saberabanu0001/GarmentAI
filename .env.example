# Copy to .env at repository root (never commit .env).
# Build Chroma: python scripts/ingest_laws.py

# groq only (LLM generation)
LLM_BACKEND=groq

# Only show / use Chroma chunks at or above this cosine similarity (0–1). Default 0.52.
# RAG_MIN_SIMILARITY=0.52


# Groq — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Whisper STT (speech-to-text) via OpenAI-compatible API
# If empty, backend falls back to GROQ_API_KEY
# WHISPER_API_KEY=
WHISPER_MODEL=whisper-large-v3
# Optional for OpenAI-compatible providers (if omitted, Groq URL is auto-used with GROQ_API_KEY)
# WHISPER_BASE_URL=

# Google Gemini (optional)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Database (future)
# DB_PASS=
