# Copy to .env at repository root (never commit .env).
# Build Chroma: python scripts/ingest_laws.py

# groq only (LLM generation)
LLM_BACKEND=groq

# Only show / use Chroma chunks at or above this cosine similarity (0–1). Default 0.52.
# RAG_MIN_SIMILARITY=0.52
# Phase-1 cost control (budget + cache + smaller context)
# RAG_ENABLE_BUDGET_ENFORCEMENT=false
# RAG_DAILY_TOKEN_LIMIT_PER_TENANT=100000
# RAG_DAILY_REQUEST_LIMIT_PER_USER=400
# RAG_RESERVED_COMPLETION_TOKENS=500
# RAG_CACHE_TTL_SECONDS=1800
# RAG_CACHE_MAX_ENTRIES=2000
# RAG_CONTEXT_CHAR_LIMIT=700
# RAG_CONTEXT_MAX_HITS_DEFAULT=6
# RAG_CONTEXT_MAX_HITS_HR=8


# Groq — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Whisper STT (speech-to-text) via OpenAI-compatible API
# If empty, backend falls back to GROQ_API_KEY
# WHISPER_API_KEY=
WHISPER_MODEL=whisper-large-v3
# Optional for OpenAI-compatible providers (if omitted, Groq URL is auto-used with GROQ_API_KEY)
# WHISPER_BASE_URL=

# Google Gemini (optional)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Auth (registration + JWT). Change JWT_SECRET in any shared environment.
# JWT_SECRET=
# JWT_EXPIRE_HOURS=72
# Approve pending users: POST /api/auth/approve with header X-Admin-Key
# AUTH_ADMIN_KEY=
# Demo: skip manual approval for new registrations
# AUTH_AUTO_APPROVE_REGISTRATIONS=true
# Require Bearer token for /api/chat and /api/voice/transcribe (set true for strict API lockdown)
# ENFORCE_AUTH_CHAT=false

# Database — pick ONE:
# Beginner (no MySQL server): file DB under data/garmentai.db, same SQLAlchemy code as MySQL
# DATABASE_URL=sqlite
# MySQL (when server is working):
# DATABASE_URL=mysql+pymysql://username:password@127.0.0.1:3306/garmentai
# DATABASE_ECHO=false
